# Database
DATABASE_URL=postgresql://fintr:fintr_secret@localhost:5432/fintr

# JWT
JWT_SECRET=change-this-to-a-long-random-string

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini AI (OpenAI-compatible proxy)
AI_BASE_URL=https://ai.dvlpid.my.id/v1
AI_MODEL=gemini-2.5-flash
AI_API_KEY=your-api-key

# App URLs
# Development: keep as localhost
# Production (Coolify): set APP_URL to frontend domain, e.g. https://fintr.dvlpid.my.id
APP_URL=http://localhost:5173
PORT=3001

# Frontend build-time variable (Vite)
# Development: leave empty (Vite proxy handles /api → localhost:3001)
# Production (Coolify Build Variable): VITE_API_URL=https://fintr-api.dvlpid.my.id/api
VITE_API_URL=
