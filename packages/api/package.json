{
  "name": "@fintr/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "start:prod": "bunx drizzle-kit migrate && bun run src/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "elysia": "^1.4.28",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/static": "^1.4.10",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  }
}
